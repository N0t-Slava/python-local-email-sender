# Local development defaults.
# Copy to .env and override values locally. Do not commit real secrets.

AWS_REGION=eu-central-1
APP_ENV=development

# Use "env" for local MailHog/dev. Use "aws" to load SMTP credentials from Secrets Manager.
SECRETS_BACKEND=env
SES_PREFLIGHT_ENABLED=false
SMTP_SECRET_ID=
SMTP_SECRET_CACHE_SECONDS=300

# Used only when SECRETS_BACKEND=env.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=test@example.com

# SES / production example:
# APP_ENV=production
# SECRETS_BACKEND=aws
# SES_PREFLIGHT_ENABLED=true
# SMTP_SECRET_ID=email-service/production/smtp
#
# When SECRETS_BACKEND=aws, SMTP_USER/SMTP_PASS are not read from .env.
# Store SMTP credentials in AWS Secrets Manager under SMTP_SECRET_ID, for example:
# {
#   "host": "email-smtp.eu-central-1.amazonaws.com",
#   "port": 587,
#   "username": "replace-with-ses-smtp-username",
#   "password": "replace-with-ses-smtp-password",
#   "from_email": "hello@example.com"
# }

PUBLIC_API_BASE_URL=http://localhost:8000
UNSUBSCRIBE_SECRET=replace-with-local-dev-secret

RABBITMQ_URL=amqp://guest:guest@localhost:5672//
CELERY_BACKEND=redis://127.0.0.1:6379/0
REDIS_URL=redis://127.0.0.1:6379/0

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/email_service
SYNC_DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/email_service
MONGO_URL=mongodb://localhost:27017/python_email_sender

DEFAULT_BATCH_SIZE=200
DEFAULT_PER_BATCH_DELAY=0.2

SES_CONFIGURATION_SET=
SNS_SES_TOPIC_ARN=

# Public domains used by deployment/proxy automation.
API_DOMAIN=api.example.com
ADMIN_DOMAIN=admin.example.com
ACME_EMAIL=admin@example.com

# Optional service credentials for local/docker helper services.
MONGO_USER=admin
MONGO_PASS=replace-with-mongo-password
REDIS_PASS=replace-with-redis-password
ES_PASS=replace-with-elasticsearch-password

# App/admin auth secrets.
JWT_SECRET=replace-with-long-random-jwt-secret
ADMIN_SECRET=replace-with-admin-api-token

# Optional Logto/identity service configuration.
DB_URL=postgres://logto:replace-with-password@postgres:5432/logto
ENDPOINT=http://localhost:3001
ADMIN_ENDPOINT=http://localhost:3002
PORT=3001
ADMIN_PORT=3002
